#!/usr/bin/env bash
# {{.SiteName}} × openclaw 一键配置脚本
#
# 该脚本由 airgate-core 在 /openclaw/install.sh 动态渲染，嵌入了当前站点的 BaseURL
# 与 provider 名称。脚本本身不发请求 airgate admin API，只用用户提供的 API Key。

set -euo pipefail

AIRGATE_BASE="{{.BaseURL}}"
PROVIDER_NAME="{{.ProviderName}}"
SITE_NAME="{{.SiteName}}"
CONFIG_DIR="${HOME}/.openclaw"
CONFIG_FILE="${CONFIG_DIR}/openclaw.json"

# ----------------------------------------------------------------------------
# 颜色与输出工具（不支持 tty 时自动降级为纯文本）
# ----------------------------------------------------------------------------
if [ -t 1 ]; then
  C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_DIM=$'\033[2m'
  C_RESET=$'\033[0m'
else
  C_BOLD= C_GREEN= C_YELLOW= C_RED= C_DIM= C_RESET=
fi

info()  { printf "%s\n" "$*"; }
ok()    { printf "${C_GREEN}✓${C_RESET} %s\n" "$*"; }
warn()  { printf "${C_YELLOW}!${C_RESET} %s\n" "$*"; }
die()   { printf "${C_RED}✗${C_RESET} %s\n" "$*" >&2; exit 1; }

# ----------------------------------------------------------------------------
# 前置检查
# ----------------------------------------------------------------------------
command -v curl >/dev/null 2>&1 || die "需要 curl，请先安装"

# 脚本走 `curl ... | bash` 时，bash 仍需要继续从 stdin 读取脚本本身，
# 不能直接 `exec < /dev/tty` 覆盖 fd 0；否则后续脚本内容会从 tty 读，表现成挂起。
# 这里单独开一个 fd 3 给交互式 read 使用。
INPUT_FD=0
if [ ! -t 0 ]; then
  if [ -r /dev/tty ]; then
    exec 3</dev/tty
    INPUT_FD=3
  else
    die "当前环境无法交互式读取输入，请下载脚本后再执行：curl -fsSL ${AIRGATE_BASE}/openclaw/install.sh -o install.sh && bash install.sh"
  fi
fi

printf "${C_BOLD}%s${C_RESET}\n" "欢迎使用 ${SITE_NAME} × openclaw 一键配置工具"
printf "${C_DIM}%s${C_RESET}\n\n" "站点: ${AIRGATE_BASE}"

# ----------------------------------------------------------------------------
# 第 1 步：读取 API Key
# ----------------------------------------------------------------------------
API_KEY=""
while [ -z "${API_KEY}" ]; do
  printf "请粘贴你的 ${SITE_NAME} API Key (sk-...): "
  # -s 隐藏输入；脚本固定由 bash 执行，管道场景下从 fd 3 (/dev/tty) 读取。
  if [ "${INPUT_FD}" -eq 0 ]; then
    read -rs API_KEY || true
  else
    read -rs -u "${INPUT_FD}" API_KEY || true
  fi
  printf "\n"
  if [ -z "${API_KEY}" ]; then
    warn "API Key 不能为空，请重试"
  fi
done

MASKED_API_KEY="****"
if [ "${#API_KEY}" -ge 4 ]; then
  MASKED_API_KEY="****${API_KEY: -4}"
fi
if [[ "${API_KEY}" == sk-* ]]; then
  MASKED_API_KEY="sk-${MASKED_API_KEY}"
fi
info "已读取 API Key: ${MASKED_API_KEY}"

# 轻量校验：调 core 自己暴露的 /v1/usage 端点。这条路由直接由 core 处理（不经过
# 任何插件），用 sk-xxx 自鉴权并返回 { is_active, balance }：
#   - 有效 key：HTTP 200
#   - key 无效/过期/未绑定分组：HTTP 401
# 比 /v1/models（依赖插件声明路由）更可靠。
info "正在校验 API Key ..."
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: Bearer ${API_KEY}" \
  "${AIRGATE_BASE}/v1/usage" || echo "000")
if [ "${HTTP_CODE}" != "200" ]; then
  die "API Key 校验失败 (HTTP ${HTTP_CODE})。请确认 Key 正确、未过期、未停用。"
fi
ok "API Key 校验通过"
echo

# ----------------------------------------------------------------------------
# 第 2 步：拉取模型预设清单
# ----------------------------------------------------------------------------
MODELS_JSON=$(curl -fsSL "${AIRGATE_BASE}/openclaw/models") \
  || die "无法从 ${AIRGATE_BASE}/openclaw/models 拉取模型列表"

# 用 python3 解析 JSON —— 大多数 Linux/macOS 都带 python3，比硬依赖 jq 更稳。
if ! command -v python3 >/dev/null 2>&1; then
  die "需要 python3（用于解析模型 JSON）。请先安装 python3 后重试。"
fi

# 先把原始 JSON 存到临时文件，后面的 python helper 都读它。
TMPDIR_SELF=$(mktemp -d)
trap 'rm -rf "${TMPDIR_SELF}"' EXIT
MODELS_FILE="${TMPDIR_SELF}/models.json"
printf "%s" "${MODELS_JSON}" > "${MODELS_FILE}"

# 展示模型列表（编号 + label + 关键能力）
info "${C_BOLD}可选模型：${C_RESET}"
python3 - "${MODELS_FILE}" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as f:
    models = json.load(f)
for i, m in enumerate(models, 1):
    label = m.get("label") or m.get("id", "?")
    api = m.get("api", "")
    caps = []
    if m.get("reasoning"): caps.append("reasoning")
    inp = m.get("input") or []
    if "image" in inp: caps.append("image")
    suffix = f"  [{api}]" + (f" {' '.join(caps)}" if caps else "")
    print(f"  [{i}] {label}{suffix}")
PY
echo

# 让用户挑选（支持 "1 3" 多选，或回车默认选 1）
SELECTION=""
while [ -z "${SELECTION}" ]; do
  printf "请输入要启用的模型编号（空格分隔，回车默认选 1）: "
  if [ "${INPUT_FD}" -eq 0 ]; then
    read -r RAW
  else
    read -r -u "${INPUT_FD}" RAW
  fi
  if [ -z "${RAW}" ]; then
    RAW="1"
  fi
  # 校验输入并过滤出合法编号
  SELECTION=$(python3 - "${MODELS_FILE}" "${RAW}" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as f:
    models = json.load(f)
raw = sys.argv[2].replace(",", " ").split()
picked = []
seen = set()
for tok in raw:
    if not tok.isdigit():
        print("ERR: 输入含非数字:", tok, file=sys.stderr); sys.exit(1)
    idx = int(tok)
    if idx < 1 or idx > len(models):
        print("ERR: 编号越界:", idx, file=sys.stderr); sys.exit(1)
    if idx not in seen:
        seen.add(idx); picked.append(str(idx))
print(" ".join(picked))
PY
  ) || SELECTION=""
  if [ -z "${SELECTION}" ]; then
    warn "输入无效，请重试"
  fi
done

# ----------------------------------------------------------------------------
# 第 3 步：生成 openclaw.json
# ----------------------------------------------------------------------------
mkdir -p "${CONFIG_DIR}"
if [ -f "${CONFIG_FILE}" ]; then
  BACKUP="${CONFIG_FILE}.bak.$(date +%s)"
  cp "${CONFIG_FILE}" "${BACKUP}"
  warn "已备份旧配置到 ${BACKUP}"
fi

MEM_ENABLED="{{if .MemorySearchEnabled}}1{{else}}0{{end}}"
MEM_MODEL="{{.MemorySearchModel}}"
GATEWAY_MODE="{{.GatewayMode}}"

# 用 python 组装 JSON，确保键顺序稳定且转义正确。
python3 - "${MODELS_FILE}" "${CONFIG_FILE}" "${PROVIDER_NAME}" "${AIRGATE_BASE}" "${API_KEY}" "${SELECTION}" "${MEM_ENABLED}" "${MEM_MODEL}" "${GATEWAY_MODE}" <<'PY'
import json, sys
models_file, config_file, provider, base, api_key, selection, mem_enabled, mem_model, gateway_mode = sys.argv[1:10]
with open(models_file, "r", encoding="utf-8") as f:
    all_models = json.load(f)
picks = [all_models[int(i) - 1] for i in selection.split()]

def clean(m):
    out = {"id": m["id"], "name": m.get("label") or m["id"], "api": m["api"]}
    if m.get("reasoning"): out["reasoning"] = True
    if m.get("input"):     out["input"] = m["input"]
    return out

primary_id = picks[0]["id"]
provider_models = [clean(m) for m in picks]
alias_map = {f"{provider}/{m['id']}": {"alias": m.get("label") or m["id"]} for m in picks}

cfg = {
    "gateway": {
        "mode": gateway_mode or "local",
    },
    "models": {
        "mode": "merge",
        "providers": {
            provider: {
                "baseUrl": f"{base}/v1",
                "apiKey":  api_key,
                "models":  provider_models,
            }
        }
    },
    "agents": {
        "defaults": {
            "model":      {"primary": f"{provider}/{primary_id}"},
            "models":     alias_map,
            "imageModel": {"primary": f"{provider}/{primary_id}"},
        }
    }
}

if mem_enabled == "1":
    cfg["agents"]["defaults"]["memorySearch"] = {
        "enabled": True,
        "provider": "openai",
        "model": mem_model,
        "remote": {"baseUrl": f"{base}/v1", "apiKey": api_key},
    }

with open(config_file, "w", encoding="utf-8") as f:
    json.dump(cfg, f, indent=2, ensure_ascii=False)
    f.write("\n")
PY

ok "已写入 ${CONFIG_FILE}"
echo
info "${C_BOLD}下一步：${C_RESET}"
info "  1. 安装 openclaw:    npm install -g openclaw@latest"
info "  2. 启动 gateway:     openclaw gateway"
echo
